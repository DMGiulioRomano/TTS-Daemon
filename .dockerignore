# Keep the Docker build context small and free of local state.
.git
.github
.gitignore
.dockerignore
Dockerfile
docker-compose.yml

# Python build/test artifacts and caches
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Local config and models (never bake private config or voices into the image)
config.yaml
*.onnx
*.onnx.json

# Docs, tests, samples, editor/OS cruft
docs/
tests/
assets/
integrations/
*.swp
.DS_Store
.idea/
.vscode/
